{
  "_browser_mcp_note": "WAF-blocked partial brands (see bridge/browser-mcp/registry.json: melia, nh, marriott, easyjet): use cursor-ide-browser when session doctor reports blocked. Agent playbooks: bridge/browser-mcp/prompts/",
  "mcpServers": {
    "cursor-ide-browser": {},
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "description": "Browser automation fallback when cursor-ide-browser is unavailable (Cursor #3878)"
    },
    "kiwi-com-flight-search": {
      "url": "https://mcp.kiwi.com"
    },
    "gondola": {
      "url": "https://mcp.gondola.ai/mcp"
    },
    "duffel": {
      "command": "node",
      "args": [
        "${workspaceFolder}/mcp/vendor/duffel-mcp/dist/index.js"
      ],
      "env": {
        "DUFFEL_ACCESS_TOKEN": "duffel_test_REPLACE_ME"
      }
    }
  }
}
